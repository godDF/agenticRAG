# Service
APP_HOST=127.0.0.1
APP_PORT=8100
# Demo mode defaults to no token. Set true before exposing the service externally.
REQUIRE_SERVICE_API_KEY=false
SERVICE_API_KEY=replace-with-a-strong-service-key
MAX_UPLOAD_MB=10

# OpenAI-compatible chat model (DeepSeek by default)
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=45

# OpenAI-compatible BGE-M3 embeddings API (no local model download)
BGE_M3_API_URL=
BGE_M3_API_KEY=
BGE_M3_MODEL=BAAI/bge-m3
BGE_M3_VECTOR_SIZE=1024
BGE_M3_TIMEOUT_SECONDS=60

# Qdrant (can reuse ChinaTravel's existing collection)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=chinatravel_safety_knowledge

# Agentic RAG limits
RAG_MAX_ROUNDS=2
RAG_MAX_SUBQUERIES=2
RAG_RETRIEVE_TOP_K=8
RAG_CONTEXT_TOP_K=4
RAG_RETRIEVE_THRESHOLD=0.40
RAG_ACCEPT_THRESHOLD=0.55
RAG_REQUEST_TIMEOUT_SECONDS=30

# DeepSeek V4-Flash official pricing (CNY / 1M tokens, checked 2026-07-16)
DEEPSEEK_CACHE_HIT_COST_PER_1M_TOKENS_CNY=0.02
DEEPSEEK_CACHE_MISS_COST_PER_1M_TOKENS_CNY=1
DEEPSEEK_OUTPUT_COST_PER_1M_TOKENS_CNY=2
# BGE-M3 is a separate provider; fill its own price if needed.
EMBEDDING_COST_PER_1M_TOKENS_CNY=0
EMBEDDING_PRICING_CONFIGURED=true
EMBEDDING_PRICING_SOURCE=SiliconFlow 官方价格

# Optional RagaAI Catalyst cloud tracing. The service still works when disabled.
RAGAAI_ENABLED=false
RAGAAI_CATALYST_ACCESS_KEY=
RAGAAI_CATALYST_SECRET_KEY=
RAGAAI_CATALYST_BASE_URL=https://catalyst.raga.ai/api
RAGAAI_PROJECT_NAME=ChinaTravel-AgenticRAG
RAGAAI_DATASET_NAME=chinatravel-rag-traces
